{
  "name": "neural-nexus",
  "version": "1.0.0",
  "description": "Neural Nexus - Core Intelligent Memory System",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dashboard:dev\"",
    "build": "tsc && npm run dashboard:build",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "lint": "eslint . --ext .ts",
    "quickstart": "node scripts/quickstart.js",
    "nexus": "node scripts/launcher.js"
  },
  "workspaces": [
    "dashboard",
    "packages/*"
  ],
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@qdrant/js-client-rest": "^1.9.0",
    "@sinclair/typebox": "^0.34.48",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "async-lock": "^1.4.1",
    "axios": "^1.7.7",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.2",
    "hono": "^4.6.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^4.68.1",
    "sharp": "^0.33.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "telegraf": "^4.16.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/async-lock": "^1.4.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.16.11",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "overrides": {
    "fast-xml-parser": "4.5.1",
    "tar": "7.5.12",
    "minimatch": "10.2.4",
    "undici": "6.24.0",
    "sqlite3": "^6.0.1",
    "glob": "11.1.0",
    "rimraf": "6.0.1",
    "inflight": "1.0.6"
  }
}
