{
  "manifest_version": 3,
  "name": "Neural Nexus: Memory Extension",
  "version": "1.0.0",
  "description": "Right-click to save highlighted text directly to your Neural Nexus brain.",
  "permissions": ["contextMenus", "storage", "activeTab"],
  "host_permissions": ["http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}
